def wind_field(i, j, nx_cells, ny_cells):
    """
    Genero un campo de viento en espiral.
    Devuelvo el vector de viento (wx, wy) en la celda (i, j).
    """
    cx, cy = nx_cells / 2.0, ny_cells / 2.0
    dx, dy = i - cx, j - cy

    tx, ty = -dy, dx
    rx, ry = -dx, -dy

    wx = 0.8 * tx + 0.2 * rx
    wy = 0.8 * ty + 0.2 * ry

    norm = np.hypot(wx, wy)
    if norm > 1e-5:
        wx = (wx / norm) * A
        wy = (wy / norm) * A

    return np.array([wx, wy])


def weight_func(u, v, nx_cells, ny_cells):
    """
    Calculo el coste de una arista incluyendo el viento.
    Hago que el coste suba si avanzo contra el viento
    y baje si avanzo a favor.
    """
    u = np.array(u)
    v = np.array(v)
    direction = v - u
    direction = direction / np.linalg.norm(direction)

    w = wind_field(u[0], u[1], nx_cells, ny_cells)
    wind_along_path = np.dot(w, direction)
    base_cost = np.linalg.norm(v - u)
    return base_cost * np.exp(-0.5 * wind_along_path)


try:
    import rasterio
    from rasterio.transform import from_bounds
