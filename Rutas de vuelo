except ImportError:
    rasterio = None


def load_raster_as_grid(path, width, height, fallback_crs=None):
    """Cargo un raster y lo ajusto a la grilla objetivo."""
    with rasterio.open(path) as ds:
        arr, transform, crs = ds.read(1), ds.transform, ds.crs
        if crs is None and fallback_crs is not None:
            crs = fallback_crs
            print(f"Aviso: {path} no tiene CRS; usando CRS de respaldo {crs}")

        dst_crs = "EPSG:4326"
        crs_str = (
            crs
            if isinstance(crs, str)
            else (crs.to_string() if crs is not None else None)
        )
        needs_resize = arr.shape != (height, width)
        needs_reproject = crs_str is not None and crs_str != dst_crs

        if needs_resize or needs_reproject:
            b = rio_transform(
                crs,
                dst_crs,
                [ds.bounds.left, ds.bounds.right],
                [ds.bounds.bottom, ds.bounds.top],
            )
            dst = np.zeros((height, width), dtype=arr.dtype)
            dst_transform = from_bounds(
                b[0][0],
                b[1][0],
                b[0][1],
                b[1][1],
                width,
                height,
            )
            reproject(
                arr,
                dst,
                src_transform=transform,
                src_crs=crs,
                dst_transform=dst_transform,
                dst_crs=dst_crs,
                resampling=Resampling.nearest,
            )
            arr, transform, crs = dst, dst_transform, dst_crs

        if crs is None:
            print(f"Aviso: {path} no tiene CRS; se asume EPSG:4326")
            crs = dst_crs
        return arr, transform, crs


def raster_latlon_to_grid(lat, lon, transform, crs, ny_cells):
    """Convierto coordenadas WGS84 a coordenadas de la grilla raster."""
    crs_str = (
        crs
        if isinstance(crs, str)
        else (crs.to_string() if crs is not None else "EPSG:4326")
    )
    if crs_str != "EPSG:4326":
        r = rio_transform("EPSG:4326", crs, [lon], [lat])
        lon, lat = r[0][0], r[1][0]
    col, row = (~transform) * (lon, lat)
    return int(round(col)), int(round(ny_cells - 1 - row))


def grid_to_latlon(x, y, transform, crs, ny_cells):
    """Convierto coordenadas de grilla (x, y) a latitud/longitud WGS84."""
    row = ny_cells - 1 - y
    lon, lat = transform * (x + 0.5, row + 0.5)
    crs_str = (
        crs
        if isinstance(crs, str)
        else (crs.to_string() if crs is not None else "EPSG:4326")
    )
    if crs_str != "EPSG:4326":
        r = rio_transform(crs, "EPSG:4326", [lon], [lat])
        lon, lat = r[0][0], r[1][0]
    return lat, lon


def grid_path_to_latlon(path, transform, crs, ny_cells):
    """Convierto una secuencia de puntos de grilla a listas (latitudes, longitudes)."""
    if not path:
        return [], []
    lats, lons = zip(
        *(grid_to_latlon(x, y, transform, crs, ny_cells) for x, y in path)
    )
    return list(lats), list(lons)


def grid_extent_latlon(transform, crs, width, height):
    """Calculo el extent geográfico para imshow en formato [lon_min, lon_max, lat_min, lat_max]."""
    left, top = transform * (0, 0)
    right, bottom = transform * (width, height)

    corners = [(left, top), (left, bottom), (right, top), (right, bottom)]
    crs_str = (
        crs
        if isinstance(crs, str)
        else (crs.to_string() if crs is not None else "EPSG:4326")
    )
    if crs_str != "EPSG:4326":
        lons, lats = zip(*corners)
        lons_t, lats_t = rio_transform(crs, "EPSG:4326", list(lons), list(lats))
        corners = list(zip(lons_t, lats_t))

    lons, lats = zip(*corners)
    return min(lons), max(lons), min(lats), max(lats)


def build_raster_graph(obstacles_grid, elevation_grid, connectivity):
    """Construyo un grafo dirigido con pesos por viento y elevación."""
    h, w = obstacles_grid.shape
    dirs = [(1, 0), (-1, 0), (0, 1), (0, -1)]
    if connectivity == 8:
        dirs += [(1, 1), (1, -1), (-1, 1), (-1, -1)]

    elev_mean = np.mean(elevation_grid)
    g2 = nx.DiGraph()
    g2.add_nodes_from(
        (x, y)
        for y in range(h)
        for x in range(w)
        if not obstacles_grid[y, x]
    )
    for x, y in g2.nodes:
        eu = float(elevation_grid[y, x])
        for dx, dy in dirs:
            nx_, ny_ = x + dx, y + dy
            if 0 <= nx_ < w and 0 <= ny_ < h and not obstacles_grid[ny_, nx_]:
                ev = float(elevation_grid[ny_, nx_])
                wind_base = weight_func((x, y), (nx_, ny_), w, h)
                g2.add_edge(
                    (x, y),
                    (nx_, ny_),
                    weight=(
                        wind_base
                        + max(0.0, ev - eu) * CLIMB_PENALTY
                        + max(0.0, (eu + ev) / 2 - elev_mean) * ELEV_PENALTY
                    ),
                )
    return g2


def reconcile_start_end_to_connected_component(graph, start, end):
    """Ajusto inicio y fin al componente conectado mas cercano si hace falta."""
    if graph.number_of_nodes() == 0:
        raise ValueError("La grilla no contiene celdas transitables")
    if start in graph and end in graph and nx.has_path(graph, start, end):
        return start, end, False

    comps = list(nx.connected_components(graph.to_undirected()))
    if not comps:
        raise ValueError("No hay componentes conectadas en la grilla")

    def nearest(nodes, ref):
        return min(nodes, key=lambda n: _sqdist(n, ref))

    pairs = [(nearest(c, start), nearest(c, end)) for c in comps]
    new_start, new_end = min(
        pairs,
        key=lambda p: _sqdist(p[0], start) + _sqdist(p[1], end),
    )
    return new_start, new_end, (new_start != start or new_end != end)


def select_waypoints_along_path(path, count):
    """Selecciono puntos intermedios repartidos de forma aproximada."""
    n = len(path) - 1
    if n <= count:
        return path[1:-1]
    idx = {
        min(max(1, int(round(i * n / (count + 1)))), n - 1)
        for i in range(1, count + 1)
    }
    return [path[i] for i in sorted(idx)]


def _cell_local_roughness(elevation_grid, x, y):
    """Estimo rugosidad local como desviación típica en vecindad 3x3."""
    h, w = elevation_grid.shape
    x0, x1 = max(0, x - 1), min(w, x + 2)
    y0, y1 = max(0, y - 1), min(h, y + 2)
    patch = elevation_grid[y0:y1, x0:x1]
    return float(np.std(patch))


def select_emergency_landing_zones(
    obstacles_grid,
    elevation_grid,
    route_cells,
    count=2,
    min_cell_distance=4,
    min_required=2,
):
    """Selecciono 2 celdas aptas, a 1-2 cuadros y en la zona central de la ruta."""
    if not route_cells:
        return []

    h, w = obstacles_grid.shape
    gy, gx = np.gradient(elevation_grid.astype(float))
    slope_mag = np.hypot(gx, gy)

    route_len = len(route_cells)
    route_last_idx = route_len - 1
    middle_idx = route_last_idx // 2
    if route_last_idx < 2:
        return []

    # Ventanas crecientes alrededor del centro para evitar fallos por exceso de rigidez.
    # Se mantiene siempre fuera del primer y último tramo de la ruta.
    window_ratios = [0.10, 0.15, 0.20, 0.25, 0.30]
    valid_windows = []
    for ratio in window_ratios:
        half_window = max(1, int(round(route_last_idx * ratio)))
        middle_start = max(1, middle_idx - half_window)
        middle_end = min(route_last_idx - 1, middle_idx + half_window)
        if middle_end > middle_start:
            valid_windows.append((middle_start, middle_end))

    if not valid_windows:
        valid_windows = [(1, route_last_idx - 1)]

    candidates = []

    def route_proximity(cell):
        best_steps = None
        best_idx = 0
        for idx, p in enumerate(route_cells):
            steps = max(abs(cell[0] - p[0]), abs(cell[1] - p[1]))
            if best_steps is None or steps < best_steps:
                best_steps = steps
                best_idx = idx
        return best_steps, best_idx

    for y in range(h):
        for x in range(w):
            if obstacles_grid[y, x]:
                continue

            elev = float(elevation_grid[y, x])
            # Celdas a elevación <= 0 m se tratan como potencial mar.
            if elev <= 0.0:
                continue

            cell = (x, y)
            route_steps, nearest_route_idx = route_proximity(cell)
            if route_steps not in (1, 2):
                continue
            roughness = _cell_local_roughness(elevation_grid, x, y)
            slope = float(slope_mag[y, x])
            score = slope + 0.4 * roughness
            candidates.append(
                (
                    cell,
                    score,
                    elev,
                    slope,
                    roughness,
                    route_steps,
                    nearest_route_idx,
                )
            )

    candidates.sort(key=lambda it: (it[5], it[1]))

    def pick_for_window(middle_start, middle_end):
        window_candidates = [
            c for c in candidates if middle_start <= c[6] <= middle_end
        ]
        if not window_candidates:
            return []

        window_mid_idx = (middle_start + middle_end) // 2
        left_candidates = [c for c in window_candidates if c[6] <= window_mid_idx]
        right_candidates = [c for c in window_candidates if c[6] >= window_mid_idx]
        left_candidates.sort(key=lambda it: (it[5], it[1]))
        right_candidates.sort(key=lambda it: (it[5], it[1]))

        selected = []

        def can_add(cell):
            return all(
                _sqdist(cell, old_cell) >= min_cell_distance**2
                for old_cell, *_ in selected
            )

        for side in (left_candidates, right_candidates):
            for cand in side:
                cell = cand[0]
                if any(cell == old_cell for old_cell, *_ in selected):
                    continue
                if can_add(cell):
                    selected.append(cand)
                    break

        if len(selected) < count:
            for cand in window_candidates:
                cell = cand[0]
                if any(cell == old_cell for old_cell, *_ in selected):
                    continue
                if can_add(cell):
                    selected.append(cand)
                    if len(selected) >= count:
                        break

        return selected[:count]

    for middle_start, middle_end in valid_windows:
        selected = pick_for_window(middle_start, middle_end)
        if len(selected) >= min_required:
            return selected[:count]

    return []


def build_route_with_tsp(graph, pts):
    """Concateno tramos de camino minimo entre puntos ordenados del TSP."""
    full_route = []
    for u, v in zip(pts[:-1], pts[1:]):
        try:
            seg = nx.shortest_path(graph, u, v, weight="weight")
            full_route.extend(seg[1:] if full_route else seg)
        except nx.NetworkXNoPath:
            print(f"No path between {u} and {v}, skipping segment")
    return full_route


def smooth_route(route, num_points=500, smoothing=2.0):
    """Suavizo la ruta con splines y conservo los extremos originales."""
    try:
        from scipy.interpolate import splev, splprep
    except ImportError:
        print("SciPy no disponible; se omite el suavizado de la ruta")
        return route

    if len(route) < 4:
        return route
    pts = [route[0]]
    for p in route[1:]:
        if p != pts[-1]:
            pts.append(p)
    if len(pts) < 4:
        return route

    try:
        xs, ys = zip(*pts)
        tck, _ = splprep([xs, ys], s=smoothing, k=3)
        xs_s, ys_s = splev(np.linspace(0, 1, num_points), tck)
        xs_s[0], ys_s[0] = route[0]
        xs_s[-1], ys_s[-1] = route[-1]
        return list(zip(xs_s, ys_s))
    except Exception:
        return route


def _save_raster_fig(
    arr,
    title,
    path,
    cmap,
    transform,
    crs,
    ny_cells,
    show_colorbar=False,
    colorbar_label="Elevación (m)",
):
    """Guardo en disco una vista previa del raster."""
    fig, ax = plt.subplots(figsize=(6, 4))
    h, w = arr.shape
    extent = grid_extent_latlon(transform, crs, w, h)
    im = ax.imshow(
        arr,
        origin="lower",
        cmap=cmap,
        extent=extent,
    )
    ax.set_xlabel("Longitud (°)")
    ax.set_ylabel("Latitud (°)")
    if show_colorbar:
        cbar = fig.colorbar(im, ax=ax, pad=0.02)
        cbar.set_label(colorbar_label)
        cbar.ax.set_title(
            f"min={np.nanmin(arr):.1f}\nmax={np.nanmax(arr):.1f}",
            fontsize=8,
            pad=8,
        )
    fig.savefig(path, dpi=150)
    plt.close(fig)


def add_wind_overlay(ax, nx_cells, ny_cells, step=3, transform=None, crs=None):
    """Superpongo vectores de viento para visualizar mejor la ruta."""
    xs = np.arange(0, nx_cells, step)
    ys = np.arange(0, ny_cells, step)
    xg, yg = np.meshgrid(xs, ys)

    lon_grid = np.zeros_like(xg, dtype=float)
    lat_grid = np.zeros_like(yg, dtype=float)
    u_lon = np.zeros_like(xg, dtype=float)
    v_lat = np.zeros_like(yg, dtype=float)

    for r in range(yg.shape[0]):
        for c in range(xg.shape[1]):
            x = int(xg[r, c])
            y = int(yg[r, c])
            wv = wind_field(x, y, nx_cells, ny_cells)

            lat0, lon0 = grid_to_latlon(x, y, transform, crs, ny_cells)
            lat1, lon1 = grid_to_latlon(
                x + 0.35 * wv[0],
                y + 0.35 * wv[1],
                transform,
                crs,
                ny_cells,
            )

            lon_grid[r, c] = lon0
            lat_grid[r, c] = lat0
            u_lon[r, c] = lon1 - lon0
            v_lat[r, c] = lat1 - lat0

    ax.quiver(
        lon_grid,
        lat_grid,
        u_lon,
        v_lat,
        color="deepskyblue",
        alpha=0.55,
        scale=1,
        scale_units="xy",
        width=0.003,
        label="Viento espiral",
        zorder=3,
    )
def render_raster_route(
    obstacles_grid,
    elevation_grid,
    full_path,
    smooth_path,
    waypoints,
    emergency_zones,
    start,
    end,
    output_path,
    city_label,
    transform,
    crs,
    nx_cells,
    ny_cells,
):
    """Renderizo y guardo la visualización final sobre elevación y obstáculos."""
    fig2, ax2 = plt.subplots(figsize=(12, 7))
    extent = grid_extent_latlon(transform, crs, nx_cells, ny_cells)
    im = ax2.imshow(
        elevation_grid,
        origin="lower",
        cmap="terrain",
        alpha=0.8,
        extent=extent,
        zorder=1,
    )
    add_wind_overlay(ax2, nx_cells, ny_cells, transform=transform, crs=crs)

    obs_y, obs_x = np.where(obstacles_grid)
    obs_lats, obs_lons = grid_path_to_latlon(
        list(zip(obs_x.tolist(), obs_y.tolist())),
        transform,
        crs,
        ny_cells,
    )
    ax2.scatter(
        obs_lons,
        obs_lats,
        c="black",
        s=18,
        marker="s",
        label="Obstáculos",
        zorder=5,
    )

    if full_path:
        full_lats, full_lons = grid_path_to_latlon(full_path, transform, crs, ny_cells)
        ax2.plot(
            full_lons,
            full_lats,
            c="orange",
            lw=1.2,
            alpha=0.6,
            label="Ruta grid",
            zorder=6,
        )
        ax2.scatter(
            full_lons,
            full_lats,
            c="orange",
            s=8,
            alpha=0.35,
            label="Puntos de ruta",
            zorder=6,
        )

    if smooth_path:
        smooth_lats, smooth_lons = grid_path_to_latlon(
            smooth_path,
            transform,
            crs,
            ny_cells,
        )
        ax2.plot(
            smooth_lons,
            smooth_lats,
            c="red",
            lw=2.5,
            label="Ruta suavizada",
            zorder=7,
        )

    if waypoints:
        way_lats, way_lons = grid_path_to_latlon(waypoints, transform, crs, ny_cells)
        ax2.scatter(
            way_lons,
            way_lats,
            c="blue",
            s=50,
