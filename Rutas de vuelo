def run_city(city, show_plots=True, save_animations=True):
    """Lanzo el flujo completo para la ciudad seleccionada."""
    cfg = CITY_CONFIG[city]
    outputs = city_outputs(city)
    print(f"\n=== Ejecutando ciudad: {cfg['label']} ===")
    return execute_raster_route(
        cfg,
        outputs,
        save_animations,
        NX_CELLS,
        NY_CELLS,
        CONNECTIVITY,
        show_plots,
    )


def parse_args():
    """Leo y valido los argumentos de línea de comandos."""
    parser = argparse.ArgumentParser(description="Ruta de drones unificada por ciudad")
    parser.add_argument(
        "--city",
        help="Ciudad objetivo: coruna, coruña, santiago o vigo",
    )
    parser.add_argument(
        "--no-show",
        action="store_true",
        help="No abrir ventanas de matplotlib",
    )
    parser.add_argument("--no-animations", action="store_true", help="No guardar GIFs")
    return parser.parse_args()


def choose_city_interactively(remaining_cities):
    """Pido por consola una ciudad pendiente de ejecutar."""
    options = list(CITY_CONFIG.keys())
    print("Opciones de ciudad disponibles:")
    for i, c in enumerate(options, start=1):
        label = CITY_CONFIG[c]["label"]
        status = "" if c in remaining_cities else " (ya ejecutada)"
        print(f"  {i}. {label}{status}")

    while True:
        raw = input("Elige ciudad (nombre o número): ").strip()
        if raw.isdigit() and 1 <= int(raw) <= len(options):
            selected = options[int(raw) - 1]
            if selected in remaining_cities:
                return selected
            print("Esa ciudad ya se ha ejecutado. Elige una pendiente.")
            continue

        c = city_key(raw)
        if c in remaining_cities:
            return c
        if c in CITY_CONFIG:
            print("Esa ciudad ya se ha ejecutado. Elige una pendiente.")
            continue

        print(
            "Entrada no válida. Escribe una ciudad pendiente o un número de la lista."
        )


def main():
    """Inicio el programa y decido la ciudad objetivo."""
    args = parse_args()
    show_plots = not args.no_show
    save_animations = SAVE_ANIMATIONS and not args.no_animations

    if args.city:
        city = city_key(args.city)
        if city not in CITY_CONFIG:
            valid = ", ".join(sorted(CITY_CONFIG.keys()) + ["coruña"])
            raise ValueError(f"Ciudad no válida: {args.city}. Usa: {valid}")
        run_city(
            city=city,
            show_plots=show_plots,
            save_animations=save_animations,
        )
        return

    collected_data = {}
    pending_cities = list(CITY_CONFIG.keys())
    while pending_cities:
        city = choose_city_interactively(pending_cities)
        data = run_city(
            city=city,
            show_plots=show_plots,
            save_animations=save_animations,
        )
        if data is not None:
            collected_data[city] = data
        pending_cities.remove(city)

    print("\nYa se han ejecutado las tres ciudades. Fin de la sesión interactiva.")
    if len(collected_data) == len(CITY_CONFIG):
        render_combined_obstacle_panel(collected_data)
        render_combined_elevation_panel(collected_data)
        render_combined_route_panel(collected_data)


if __name__ == "__main__":
    main()
