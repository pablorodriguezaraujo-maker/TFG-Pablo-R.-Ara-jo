def execute_raster_route(
    cfg,
    outputs,
    save_animations,
    nx_cells,
    ny_cells,
    connectivity,
    show_plots,
):
    """Ejecuto todo el flujo de ruteo raster para una ciudad."""
    if rasterio is None:
        print("Rasterio no esta disponible; se omite la ruta basada en archivos raster")
        return

    obs_file = require_file(cfg["obstacle_raster"], "raster de obstáculos")
    elev_file = require_file(cfg["elevation_raster"], "raster de elevación")
    with rasterio.open(elev_file) as ds_elev:
        elev_fallback_crs = ds_elev.crs

    elev_arr, elev_transform, elev_crs = load_raster_as_grid(
        elev_file,
        nx_cells,
        ny_cells,
    )
    elev_arr = np.flipud(elev_arr)
    obs_arr, _, _ = load_raster_as_grid(
        obs_file,
        nx_cells,
        ny_cells,
        fallback_crs=elev_fallback_crs,
    )
    obs_arr = np.flipud(obs_arr)

    obstacles_grid = (obs_arr > POP_THRESHOLD).astype(np.uint8)
    print(
        "Obstáculos: "
        f"{np.sum(obstacles_grid)} celdas | "
        f"Elevación: {np.min(elev_arr):.0f}-{np.max(elev_arr):.0f} m"
    )

    _save_raster_fig(
        obstacles_grid,
        f"Raster Obstáculos - {cfg['label']}",
        outputs["obstacle_preview"],
        "gray",
        elev_transform,
        elev_crs,
        ny_cells,
        show_colorbar=False,
    )
    _save_raster_fig(
        elev_arr,
        f"Raster Elevación - {cfg['label']}",
        outputs["elevation_preview"],
        "terrain",
        elev_transform,
        elev_crs,
        ny_cells,
        show_colorbar=True,
        colorbar_label="Elevación (m)",
    )

    start = raster_latlon_to_grid(
        *cfg["start_latlon"],
        elev_transform,
        elev_crs,
        ny_cells,
    )
    end = raster_latlon_to_grid(*cfg["end_latlon"], elev_transform, elev_crs, ny_cells)
    print(f"Inicio obligatorio (lat,lon): {cfg['start_latlon']} -> celda {start}")
    print(f"Fin obligatorio (lat,lon): {cfg['end_latlon']} -> celda {end}")

    if any(not (0 <= p[0] < nx_cells and 0 <= p[1] < ny_cells) for p in (start, end)):
        raise ValueError("Inicio o fin fuera de la grilla")

    if obstacles_grid[start[1], start[0]] or obstacles_grid[end[1], end[0]]:
        print(
            "Inicio/Fin obligatorios detectados sobre obstáculo; "
            "se habilitan esas dos celdas para mantener tus puntos fijos"
        )
    for x, y in (start, end):
        obstacles_grid[y, x] = 0

    g_raster = build_raster_graph(obstacles_grid, elev_arr, connectivity)
    start_used, end_used, adjusted = reconcile_start_end_to_connected_component(
        g_raster,
        start,
        end,
    )
    if adjusted:
        print(
            f"Ajuste por conectividad: inicio {start} -> {start_used} | "
            f"fin {end} -> {end_used}"
        )

    try:
        path = nx.shortest_path(g_raster, start_used, end_used, weight="weight")
    except nx.NetworkXNoPath as e:
        raise ValueError(
            "No existe camino entre inicio y fin ni tras el ajuste de "
            f"conectividad: {start_used} -> {end_used}"
        ) from e

    inter = select_waypoints_along_path(path, cfg["waypoint_count"])
    full_route = build_route_with_tsp(g_raster, [start_used] + inter + [end_used])
    emergency_zones = select_emergency_landing_zones(
        obstacles_grid,
        elev_arr,
        route_cells=full_route,
        count=2,
        min_required=2,
    )
    forced_emergency = cfg.get("emergency_latlon") or []
    if forced_emergency:
        emergency_zones = []
        gy, gx = np.gradient(elev_arr.astype(float))
        slope_mag = np.hypot(gx, gy)
        for lat, lon in forced_emergency[:2]:
            x, y = raster_latlon_to_grid(lat, lon, elev_transform, elev_crs, ny_cells)
            if not (0 <= x < nx_cells and 0 <= y < ny_cells):
                raise ValueError(
                    f"Coordenada de emergencia fuera de grilla: lat={lat}, lon={lon}"
                )
            nearest_idx, nearest_cell = min(
                enumerate(full_route),
                key=lambda it: max(abs(x - it[1][0]), abs(y - it[1][1])),
            )
            route_steps = max(abs(x - nearest_cell[0]), abs(y - nearest_cell[1]))
            roughness = _cell_local_roughness(elev_arr, x, y)
            slope = float(slope_mag[y, x])
            score = slope + 0.4 * roughness
            emergency_zones.append(
                ((x, y), score, float(elev_arr[y, x]), slope, roughness, route_steps, nearest_idx)
            )
    if len(emergency_zones) < 2:
        raise ValueError(
            "No se pudieron encontrar al menos 2 zonas de aterrizaje de "
            "emergencia muy próximas a la ruta y fuera de mar"
        )

    heights = [float(elev_arr[y, x]) for x, y in full_route]
    route_len = sum(
        np.hypot(b[0] - a[0], b[1] - a[1])
        for a, b in zip(full_route, full_route[1:])
    )
    climb = sum(max(0.0, b - a) for a, b in zip(heights, heights[1:]))
    main_cost = nx.shortest_path_length(g_raster, start_used, end_used, weight="weight")

    print(f"\n--- RUTA OPTIMIZADA RASTER ---\nInicio: {start_used} | Fin: {end_used}")
    print(f"Puntos intermedios objetivo ({cfg['waypoint_count']}): {inter}")
    print(f"Longitud: {route_len:.2f} | Coste: {main_cost:.2f}")
    print(f"Elevación media: {np.mean(heights):.1f} m | Ascenso: {climb:.1f} m")
    print("\nZonas de aterrizaje de emergencia propuestas:")
    if not emergency_zones:
        print("  No se encontraron celdas válidas con los criterios actuales")
    for idx, (
        cell,
        score,
        elev,
        slope,
        roughness,
        route_steps,
        nearest_route_idx,
    ) in enumerate(
        emergency_zones,
        start=1,
    ):
        if forced_emergency and idx <= len(forced_emergency):
            lat, lon = forced_emergency[idx - 1]
        else:
            lat, lon = grid_to_latlon(cell[0], cell[1], elev_transform, elev_crs, ny_cells)
        route_pct = 100.0 * nearest_route_idx / max(1, len(full_route) - 1)
        print(
            f"  Z{idx}: celda={cell} | lat={lat:.8f}, lon={lon:.8f} | "
            f"elev={elev:.1f} m | pendiente={slope:.3f} | rugosidad={roughness:.3f} | "
            f"dist_ruta={route_steps} cuadros | tramo_ruta={route_pct:.1f}% | score={score:.3f}"
        )

    smooth = smooth_route(full_route)
    render_raster_route(
        obstacles_grid,
        elev_arr,
        full_route,
        smooth,
        inter,
        emergency_zones,
        start_used,
        end_used,
        outputs["route_png"],
        cfg["label"],
        elev_transform,
        elev_crs,
        nx_cells,
        ny_cells,
    )
    print(f"Ruta guardada en: {outputs['route_png']}")

    anim_path = smooth or full_route
    fig_a, ax_a = plt.subplots(figsize=(12, 7))
    extent = grid_extent_latlon(elev_transform, elev_crs, nx_cells, ny_cells)
    im_a = ax_a.imshow(
