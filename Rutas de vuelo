def _draw_route_on_ax(
    ax,
    obstacles_grid,
    elevation_grid,
    full_path,
    smooth_path,
    waypoints,
    emergency_zones,
    start,
    end,
    transform,
    crs,
    nx_cells,
    ny_cells,
):
    """Dibuja todos los elementos de ruta sobre un eje ya creado."""
    extent = grid_extent_latlon(transform, crs, nx_cells, ny_cells)
    im = ax.imshow(
        elevation_grid,
        origin="lower",
        cmap="terrain",
        alpha=0.8,
        extent=extent,
        aspect="auto",
        zorder=1,
    )
    add_wind_overlay(ax, nx_cells, ny_cells, transform=transform, crs=crs)

    obs_y, obs_x = np.where(obstacles_grid)
    obs_lats, obs_lons = grid_path_to_latlon(
        list(zip(obs_x.tolist(), obs_y.tolist())),
        transform, crs, ny_cells,
    )
    ax.scatter(obs_lons, obs_lats, c="black", s=8, marker="s", zorder=5)

    if full_path:
        full_lats, full_lons = grid_path_to_latlon(full_path, transform, crs, ny_cells)
        ax.plot(full_lons, full_lats, c="orange", lw=1.0, alpha=0.6, zorder=6)
        ax.scatter(full_lons, full_lats, c="orange", s=4, alpha=0.35, zorder=6)

    if smooth_path:
        smooth_lats, smooth_lons = grid_path_to_latlon(smooth_path, transform, crs, ny_cells)
        ax.plot(smooth_lons, smooth_lats, c="red", lw=2.0, zorder=7)

    if waypoints:
        way_lats, way_lons = grid_path_to_latlon(waypoints, transform, crs, ny_cells)
        ax.scatter(way_lons, way_lats, c="blue", s=30, marker="o", zorder=8)

    if emergency_zones:
        e_cells = [cell for cell, *_ in emergency_zones]
        e_lats, e_lons = grid_path_to_latlon(e_cells, transform, crs, ny_cells)
        ax.scatter(
            e_lons, e_lats, c="cyan", s=55, marker="^",
            edgecolors="black", linewidths=0.5, zorder=8,
        )

    s_lat, s_lon = grid_to_latlon(start[0], start[1], transform, crs, ny_cells)
    e_lat, e_lon = grid_to_latlon(end[0], end[1], transform, crs, ny_cells)
    ax.scatter([s_lon], [s_lat], c="green", s=100, marker="*", zorder=9)
    ax.scatter([e_lon], [e_lat], c="magenta", s=100, marker="X", zorder=9)

    return im


