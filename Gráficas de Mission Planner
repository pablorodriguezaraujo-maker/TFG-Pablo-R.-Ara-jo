def compare_motors_panels(visualizers):
    """Crea una figura 2+1 con las salidas de motores de cada ciudad."""
    fig, axes = _create_city_panel_figure(tall=True)
    plotted = False
    legend_handles = None
    legend_labels = None

    for key, ax in axes.items():
        viz = visualizers.get(key)
        if viz is None:
            ax.axis('off')
            continue
        sources = viz.data.get('RCOU', []) + viz.data.get('RCO2', [])
        if not sources:
            ax.axis('off')
            continue

        motors = {f'Motor{i}': [] for i in range(1, 9)}
        motor_times = {f'Motor{i}': [] for i in range(1, 9)}
        source_time_axis = viz._build_time_axis_from_messages_global(sources)

        for msg_idx, msg in enumerate(sources):
            for i in range(1, 9):
                candidates = (f'Ch{i}', f'C{i}', f'Servo{i}', f'SERVO{i}', f'chan{i}_raw')
                value = None
                if isinstance(msg, dict):
                    for candidate in candidates:
                        if candidate in msg:
                            value = msg[candidate]
                            break
                else:
                    for candidate in candidates:
                        if hasattr(msg, candidate):
                            value = getattr(msg, candidate)
                            break
                if value is not None:
                    try:
                        pwm = float(value)
                        if PWM_MIN <= pwm <= PWM_MAX:
                            motors[f'Motor{i}'].append(pwm)
                            motor_times[f'Motor{i}'].append(source_time_axis[msg_idx])
                    except (TypeError, ValueError):
                        pass

        if not any(motors.values()):
            ax.axis('off')
            continue

        for i, (motor_name, values) in enumerate(motors.items(), 1):
            if values:
                ax.plot(
                    motor_times[motor_name],
                    values,
                    linewidth=1.0,
                    color=f'C{i - 1}',
                    label=f'M{i}',
                )

        _style_city_panel_axis(ax, key, 'Tiempo (s)', 'PWM (µs)')
        if legend_handles is None:
            legend_handles, legend_labels = ax.get_legend_handles_labels()
        plotted = True

    if not plotted:
        plt.close(fig)
        print("⚠ No hay datos de motores para comparar")
        return

    _hide_unused_city_axes(axes, visualizers)
    _figure_legend(fig, legend_handles, legend_labels, ncol=4, y=0.05)
    fig.tight_layout(pad=0.4)
    fig.subplots_adjust(bottom=0.16)
    _save_comparison_figure(fig, 'panel_motores_ciudades')
    plt.show()


