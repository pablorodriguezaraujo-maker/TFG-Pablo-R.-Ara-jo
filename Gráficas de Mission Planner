    def visualize_motors(self):
        """Grafica la señal PWM de los 8 motores del octorotor.

        Fuente de datos: mensajes ``RCOU`` y/o ``RCO2``.
        Para cada motor busca el campo por varios nombres candidatos
        (Ch1…Ch8, C1…C8, Servo1…Servo8, etc.) y filtra valores fuera
        del rango PWM físico [``PWM_MIN``, ``PWM_MAX``].
        """
        # Combina fuentes RCOU y RCO2 si existen
        sources = self.data.get('RCOU', []) + self.data.get('RCO2', [])
        if not sources:
            print("⚠ Datos de RCOU/RCO2 (salidas de motores) no encontrados")
            return

        # Inicializa listas vacías para cada uno de los 8 motores
        motors = {f'Motor{i}': [] for i in range(1, 9)}
        motor_times = {f'Motor{i}': [] for i in range(1, 9)}
        source_time_axis = self._build_time_axis_from_messages_global(sources)

        for msg_idx, msg in enumerate(sources):
            for i in range(1, 9):
                # Nombres de campo usados por distintas versiones de firmware
                candidates = (
                    f'Ch{i}', f'C{i}',
                    f'Servo{i}', f'SERVO{i}',
                    f'chan{i}_raw',
                )

                value = None
                if isinstance(msg, dict):
                    for key in candidates:
                        if key in msg:
                            value = msg[key]
                            break
                else:
                    for key in candidates:
                        if hasattr(msg, key):
                            value = getattr(msg, key)
                            break

                if value is not None:
                    try:
                        pwm = float(value)
                        # Descarta valores fuera del rango PWM físico
                        if PWM_MIN <= pwm <= PWM_MAX:
                            motors[f'Motor{i}'].append(pwm)
                            motor_times[f'Motor{i}'].append(source_time_axis[msg_idx])
                    except (TypeError, ValueError):
                        pass

        if not any(motors.values()):
            print(
                "⚠ Se encontraron mensajes de salida, "
                "pero sin canales de motores válidos"
            )
            return

        fig, ax = plt.subplots(
            1, 1,
            figsize=(CITY_PLOT_WIDTH_IN, CITY_PLOT_HEIGHT_TALL_IN),
        )
        for i, (motor_name, values) in enumerate(motors.items(), 1):
            if values:
                ax.plot(
                    motor_times[motor_name],
                    values,
                    linewidth=1.25,
                    color=f'C{i - 1}',
                    label=motor_name,
                )

        ax.set_xlabel('Tiempo (s)', labelpad=2)
        ax.set_ylabel('PWM (µs)')
        ax.grid(True, alpha=0.3)
        self._legend_below(ax, ncol=2, y=-0.20)
        fig.tight_layout(rect=(0.0, 0.16, 1.0, 1.0))
        self._save_figure(fig, 'motores')
        plt.show()

