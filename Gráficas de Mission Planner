def _normalize_to_percent(values, n_points=100):
    """Remuestrea una serie a ``n_points`` puntos equiespaciados (0-100 %).

    Permite comparar series de distinta longitud sobre el mismo eje X
    que representa el porcentaje de progreso del vuelo.

    Parámetros:
        values (list[float]): Serie original de cualquier longitud.
        n_points (int): Número de puntos de la serie de salida.

    Devuelve:
        list[float]: Serie interpolada linealmente de ``n_points`` valores.
    """
    n = len(values)
    if n == 0:
        return []
    if n == 1:
        return [values[0]] * n_points

    result = []
    for i in range(n_points):
        idx_f = i * (n - 1) / (n_points - 1)
        idx_lo = int(idx_f)
        idx_hi = min(idx_lo + 1, n - 1)
        frac = idx_f - idx_lo
        result.append(values[idx_lo] * (1 - frac) + values[idx_hi] * frac)
    return result


def _save_comparison_figure(fig, base_filename):
    """Guarda una figura de comparativa en la carpeta comparativas.

    Parámetros:
        fig: Objeto figura de matplotlib.
        base_filename (str): Nombre base sin extensión, p.ej.
            'velocidad_comparativa'.
    """
    COMPARISON_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    filename = f"{base_filename}.png"
    filepath = COMPARISON_OUTPUT_DIR / filename
    try:
        # Mantiene el tamaño físico de la figura sin recortes automáticos.
        fig.savefig(filepath, dpi=EXPORT_DPI)
        print(f"  ✓ Comparativa guardada: {filepath.name}")
    except Exception as exc:
        print(f"  ✗ Error guardando {filename}: {exc}")


def _create_city_panel_figure(tall=False):
