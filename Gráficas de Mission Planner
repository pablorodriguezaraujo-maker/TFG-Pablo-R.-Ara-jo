def compare_altitude_vs_distance(visualizers):
    """Grafica el perfil de altitud en función de la distancia acumulada.

    El eje X representa kilómetros recorridos desde el despegue, lo que
    permite comparar cómo varía la altitud a lo largo de cada ruta
    independientemente del tiempo de vuelo.

    Parámetros:
        visualizers (dict): Visualizadores cargados por clave de ciudad.
    """
    plt.figure(figsize=(13, 6))
    plotted = False

    for key in CITY_ORDER:
        if key not in visualizers:
            continue
        viz = visualizers[key]
        points = viz._get_valid_gps_points()
        if len(points) < 2:
            continue

        # Distancia acumulada entre puntos GPS consecutivos (km)
        dist_km = [0.0]
        for i in range(1, len(points)):
            d_m = MissionPlannerVisualizer._haversine_m(
                points[i - 1][0], points[i - 1][1],
                points[i][0], points[i][1],
            )
            dist_km.append(dist_km[-1] + d_m / 1000.0)

        # Altitud barométrica normalizada a la misma cantidad de puntos
        baro = viz._extract_series('BARO', ('Alt',))
        if baro is None or len(baro['Alt']) < 2:
            continue

        n = len(dist_km)
        alt_norm = _normalize_to_percent(baro['Alt'], n_points=n)

        plt.plot(
            dist_km, alt_norm,
            linewidth=2.5,
            label=CITY_LABELS[key],
            color=CITY_COLORS[key],
        )
        plotted = True

    if not plotted:
        print("⚠ No hay datos suficientes para comparar altitud vs distancia")
        return

    plt.xlabel('Distancia recorrida (km)')
    plt.ylabel('Altitud (m)')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    _save_comparison_figure(plt.gcf(), 'altitud_vs_distancia')
    plt.show()


def compare_gps_tracks(visualizers):
    """Superpone las trayectorias GPS centradas en el punto de despegue.

    Convierte las coordenadas geográficas de cada ciudad a metros de
    desplazamiento relativo respecto al primer punto (origen = (0, 0))
    para poder representar todas las rutas en la misma escala aunque
    se encuentren en lugares geográficos distintos.

    Los marcadores circulares indican el inicio y los cuadrados el final.

    Parámetros:
        visualizers (dict): Visualizadores cargados por clave de ciudad.
    """
    plt.figure(figsize=(10, 9))
    plotted = False

    for key in CITY_ORDER:
        if key not in visualizers:
            continue
        points = visualizers[key]._get_valid_gps_points()
        if len(points) < 2:
            continue

        lat0, lon0, _ = points[0]
        # Factor de escala longitud → metros según la latitud del origen
        lon_to_m = LAT_TO_M * math.cos(math.radians(lat0))

        x_m = [(p[1] - lon0) * lon_to_m for p in points]
        y_m = [(p[0] - lat0) * LAT_TO_M for p in points]

        color = CITY_COLORS[key]
        plt.plot(x_m, y_m, linewidth=1.8, label=CITY_LABELS[key], color=color)
        # Punto de inicio (círculo) y fin (cuadrado)
        plt.scatter([x_m[0]], [y_m[0]], color=color, s=90,
                    marker='o', zorder=5)
        plt.scatter([x_m[-1]], [y_m[-1]], color=color, s=90,
                    marker='s', zorder=5)
        plotted = True

    if not plotted:
        print("⚠ No hay datos GPS suficientes para comparar")
        return

    plt.xlabel('Desplazamiento Este-Oeste (m)')
    plt.ylabel('Desplazamiento Norte-Sur (m)')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.axis('equal')
    plt.tight_layout()
    _save_comparison_figure(plt.gcf(), 'gps_comparativa')
    plt.show()


def compare_metrics_dashboard(visualizers):
    """Dashboard de barras con las métricas clave de cada ciudad.

    Muestra en una sola figura 5 subgráficas de barras:
    - Distancia total (km)
    - Duración del vuelo (min)
    - Velocidad media (km/h)
    - Altitud máxima (m)
    - Voltaje mínimo de batería (V)

    Parámetros:
        visualizers (dict): Visualizadores cargados por clave de ciudad.
    """
    keys = [k for k in CITY_ORDER if k in visualizers]
    labels = [CITY_LABELS[k] for k in keys]
    bar_colors = [CITY_COLORS[k] for k in keys]

    dist_km = []
    dur_min = []
    vel_media_kmh = []
    alt_max_m = []
    bat_min_v = []

    for key in keys:
        viz = visualizers[key]

        # --- Distancia y duración ---
        points = viz._get_valid_gps_points()
        if len(points) >= 2:
            total_m = sum(
                MissionPlannerVisualizer._haversine_m(
                    points[i - 1][0], points[i - 1][1],
                    points[i][0], points[i][1],
                )
                for i in range(1, len(points))
            )
            times = [p[2] for p in points if p[2] is not None]
            total_s = (
                max(0.0, (times[-1] - times[0]) / US_TO_S)
                if len(times) >= 2 else 0.0
            )
        else:
            total_m = total_s = 0.0

        dist_km.append(total_m / 1000.0)
        dur_min.append(total_s / 60.0)
        vel_media_kmh.append(
            (total_m / total_s * 3.6) if total_s > 0 else 0.0
        )

        # --- Altitud máxima ---
        baro = viz._extract_series('BARO', ('Alt',))
        alt_max_m.append(max(baro['Alt']) if baro and baro['Alt'] else 0.0)

        # --- Voltaje mínimo de batería ---
        bat = viz._extract_series('BAT', ('Volt',))
        if bat:
            volts = [v for v in bat['Volt'] if BAT_VOLT_MIN < v <= BAT_VOLT_MAX]
            bat_min_v.append(min(volts) if volts else 0.0)
        else:
            bat_min_v.append(0.0)

    # Datos agrupados: (valores, título del panel, unidad, formato de número)
    metricas = [
        (dist_km,       'Distancia total',         'km',   '{:.2f} km'),
        (dur_min,       'Duración del vuelo',       'min',  '{:.1f} min'),
        (vel_media_kmh, 'Velocidad media',          'km/h', '{:.1f} km/h'),
        (alt_max_m,     'Altitud máxima',           'm',    '{:.0f} m'),
        (bat_min_v,     'Voltaje mínimo batería',   'V',    '{:.2f} V'),
    ]

    # Rejilla 2×3: 5 paneles de barras + 1 panel de resumen textual
    # constrained_layout evita recortes del título y solapes entre paneles.
    fig, axes = plt.subplots(2, 3, figsize=(16.8, 9.2), constrained_layout=True)
    fig.patch.set_facecolor('#f0f2f5')

    ax_flat = axes.flatten()

    for idx, (values, title, xlabel, fmt) in enumerate(metricas):
        ax = ax_flat[idx]
        ax.set_facecolor('#ffffff')

        # Invertir para que la primera ciudad aparezca arriba
        inv_labels = list(reversed(labels))
        inv_values = list(reversed(values))
        inv_colors = list(reversed(bar_colors))

        max_val = max(inv_values) if inv_values else 1.0

        bars = ax.barh(
            inv_labels, inv_values,
            color=inv_colors,
            edgecolor='white',
            linewidth=1.0,
            height=0.30,
        )

        # Valor a la derecha de cada barra
        for bar, val in zip(bars, inv_values):
            bar_w = bar.get_width()
            offset = max_val * 0.02
            # Texto dentro si hay espacio, fuera si la barra es corta
            if bar_w > max_val * 0.25:
                ax.text(
                    bar_w - offset,
                    bar.get_y() + bar.get_height() / 2,
                    fmt.format(val),
                    ha='right', va='center',
                    fontsize=11, fontweight='bold', color='white',
                )
            else:
                ax.text(
                    bar_w + offset,
                    bar.get_y() + bar.get_height() / 2,
                    fmt.format(val),
                    ha='left', va='center',
                    fontsize=11, fontweight='bold', color='#333333',
                )

        for bar, city_name in zip(bars, inv_labels):
            bar_w = bar.get_width()
            x_city = max(bar_w * 0.5, max_val * 0.06)
            y_city = bar.get_y() - (bar.get_height() * 0.55)
            ax.text(
                x_city,
                y_city,
                city_name,
                ha='center',
                va='top',
                fontsize=11,
                color='#444444',
            )

        ax.set_xlabel(xlabel, fontsize=11, color='#555555')
        ax.set_xlim(0, max_val * 1.18)
        ax.tick_params(axis='y', left=False, labelleft=False)
        ax.tick_params(axis='x', labelsize=11)
        ax.margins(x=0.0, y=0.28)
        ax.spines[['top', 'right']].set_visible(False)
        ax.grid(axis='x', alpha=0.25, linestyle='--')

    # --- Panel de resumen textual (celda [1,2]) ---
    ax_sum = ax_flat[5]
    ax_sum.set_facecolor('#ffffff')
    ax_sum.axis('off')
    ax_sum.margins(0.0)  # Sin margen interno para aprovechar el espacio

    # Cabecera compacta para evitar solapes de texto en columnas estrechas
    col_headers = ['Ciudad', 'Dist', 'Dur', 'Vel', 'Alt', 'Bat']

    def _city_label_for_table(city_key):
        """Devuelve un nombre compacto para que no se solape la fila."""
        if city_key == 'santiago':
            return 'Santiago'
        return CITY_LABELS[city_key]

    rows = []
    for i, key in enumerate(keys):
        rows.append([
            _city_label_for_table(key),
            f'{dist_km[i]:.2f}',
            f'{dur_min[i]:.1f}',
            f'{vel_media_kmh[i]:.1f}',
            f'{alt_max_m[i]:.0f}',
            f'{bat_min_v[i]:.2f}',
        ])

    table = ax_sum.table(
        cellText=rows,
        colLabels=col_headers,
        cellLoc='center',
        bbox=[0.00, 0.00, 1.00, 1.00],  # Ocupa todo el panel para evitar huecos
        colWidths=[0.25, 0.19, 0.14, 0.18, 0.10, 0.14],
    )
    table.auto_set_font_size(False)
    table.set_fontsize(11)
    table.scale(1.20, 1.42)

    # Color de cabecera oscuro, filas con color de ciudad
    for (row, col), cell in table.get_celld().items():
        cell.PAD = 0.06
        cell.set_edgecolor('#bbbbbb')
        cell.set_linewidth(0.5)
        if row == 0:
            cell.set_facecolor('#2a2a2a')
            cell.set_text_props(color='white', fontweight='bold', fontsize=11)
        elif row <= len(keys):
            city_key = keys[row - 1]
            r, g, b = plt.matplotlib.colors.to_rgb(CITY_COLORS[city_key])
            cell.set_facecolor((r, g, b, 0.12))

        # Primera columna alineada a la izquierda para mejor legibilidad.
        if col == 0 and row > 0:
            cell.get_text().set_ha('left')

    # Compacta la separación entre paneles para reducir espacios en blanco.
    fig.set_constrained_layout_pads(h_pad=0.02, w_pad=0.02, hspace=0.02,
                                    wspace=0.02)
    _save_comparison_figure(fig, 'dashboard_metricas')
    plt.show()


def compare_battery(visualizers):
    """Superpone el perfil de voltaje de batería de las tres ciudades.

    El eje X representa el progreso del vuelo (0-100 %) para que la
    comparación sea independiente de la duración de cada misión.

    Parámetros:
        visualizers (dict): Visualizadores cargados por clave de ciudad.
    """
    x = list(range(100))

    plt.figure(figsize=(13, 6))
    plotted = False

    for key in CITY_ORDER:
        if key not in visualizers:
            continue
        bat = visualizers[key]._extract_series('BAT', ('Volt',))
        if bat is None:
            continue
        volts = [v for v in bat['Volt'] if BAT_VOLT_MIN < v <= BAT_VOLT_MAX]
        if len(volts) < 2:
            continue
        plt.plot(
            x, _normalize_to_percent(volts),
            linewidth=2.5,
            label=CITY_LABELS[key],
            color=CITY_COLORS[key],
        )
        plotted = True

    if not plotted:
        print("⚠ No hay datos de batería para comparar")
        return

    plt.xlabel('Progreso del vuelo (%)')
    plt.ylabel('Voltaje (V)')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    _save_comparison_figure(plt.gcf(), 'bateria_comparativa')
    plt.show()


def _run_comparison_session(visualizers):
    """Menú interactivo de gráficas comparativas entre las tres ciudades.

    Parámetros:
        visualizers (dict): Visualizadores cargados por clave de ciudad.
    """
    print("\nGráficas comparativas disponibles:")
    opciones_comp = [
        ("1", "Velocidad normalizada (progreso del vuelo %)"),
        ("2", "Altitud barométrica normalizada (progreso del vuelo %)"),
        ("3", "Perfil de altitud vs distancia recorrida"),
        ("4", "Trayectorias GPS centradas en el origen"),
        ("5", "Dashboard de métricas (distancia, tiempo, vel. media…)"),
        ("6", "Voltaje de batería normalizado"),
        ("7", "Todas las comparativas superpuestas"),
        ("8", "Paneles por ciudad (2 arriba + 1 abajo centrada)"),
        ("9", "Todas las comparativas"),
        ("0", "Omitir"),
    ]
    for num, desc in opciones_comp:
        print(f"  {num}. {desc}")

    eleccion = input(
        "\nSelecciona opción(es) (0-9), "
        "separadas por coma, p.ej. 1,3,8: "
    ).strip()

    if not eleccion:
        return

    seleccionadas = [c.strip() for c in eleccion.split(',') if c.strip()]

    if '0' in seleccionadas:
        return

    acciones_comp = {
        '1': lambda: compare_speed(visualizers),
        '2': lambda: compare_altitude(visualizers),
        '3': lambda: compare_altitude_vs_distance(visualizers),
        '4': lambda: compare_gps_tracks(visualizers),
        '5': lambda: compare_metrics_dashboard(visualizers),
        '6': lambda: compare_battery(visualizers),
        '8': lambda: compare_all_city_panels(visualizers),
    }

    todas_superpuestas = [
        '1', '2', '3', '4', '5', '6',
    ]

    todas = [
        '1', '2', '3', '4', '5', '6', '8',
    ]

    if '7' in seleccionadas:
        seleccionadas = todas_superpuestas

    if '9' in seleccionadas:
        seleccionadas = todas

    for opt in seleccionadas:
        accion = acciones_comp.get(opt)
        if accion is None:
            print(f"Opción no válida: {opt}")
            continue
        try:
            accion()
        except Exception as exc:
            print(f"Error en comparativa {opt}: {exc}")


