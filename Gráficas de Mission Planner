        plt.title(self._title_with_city('Altitud respecto al terreno (AGL)'))
        plt.legend()
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        self._save_figure(plt.gcf(), 'altitud_terreno')
        plt.show()

    def visualize_gps(self):
        """Grafica la trayectoria GPS del dron sobre un plano lon/lat.

        Fuente de datos: campos ``Lat`` y ``Lng`` de mensajes ``GPS``.
        Los puntos se colorean según el orden temporal para indicar
        el avance de la ruta.
        """
        if 'GPS' not in self.data:
            print("⚠ Datos de GPS no encontrados")
            return

        raw = self._extract_series('GPS', ('Lat', 'Lng'))
        lat_list = []
        lon_list = []

        for lat, lon in zip(raw['Lat'], raw['Lng']):
            # Normaliza si las coordenadas vienen en grados × 1e7
            if abs(lat) > GPS_RAW_THRESHOLD or abs(lon) > GPS_RAW_THRESHOLD:
                lat /= GPS_SCALE_FACTOR
                lon /= GPS_SCALE_FACTOR

            if -90 <= lat <= 90 and -180 <= lon <= 180:
                lat_list.append(lat)
                lon_list.append(lon)

        if len(lat_list) < 2:
            print("⚠ No hay suficientes puntos GPS válidos para graficar")
            return

        plt.figure(figsize=(10, 8))
        scatter = plt.scatter(
            lon_list, lat_list,
            c=range(len(lat_list)),
            cmap='viridis',
            s=10,
        )
        plt.xlabel('Longitud')
        plt.ylabel('Latitud')
        plt.title(self._title_with_city('Trayectoria GPS del Octorotor'))
        plt.colorbar(scatter, label='Tiempo (muestras)')
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        self._save_figure(plt.gcf(), 'gps')
        plt.show()

    def visualize_motors(self):
        """Grafica la señal PWM de los 8 motores del octorotor.

        Fuente de datos: mensajes ``RCOU`` y/o ``RCO2``.
        Para cada motor busca el campo por varios nombres candidatos
        (Ch1…Ch8, C1…C8, Servo1…Servo8, etc.) y filtra valores fuera
        del rango PWM físico [``PWM_MIN``, ``PWM_MAX``].
        """
        # Combina fuentes RCOU y RCO2 si existen
        sources = self.data.get('RCOU', []) + self.data.get('RCO2', [])
        if not sources:
            print("⚠ Datos de RCOU/RCO2 (salidas de motores) no encontrados")
            return

        # Inicializa listas vacías para cada uno de los 8 motores
        motors = {f'Motor{i}': [] for i in range(1, 9)}

        for msg in sources:
            for i in range(1, 9):
                # Nombres de campo usados por distintas versiones de firmware
                candidates = (
                    f'Ch{i}', f'C{i}',
                    f'Servo{i}', f'SERVO{i}',
                    f'chan{i}_raw',
                )

                value = None
                if isinstance(msg, dict):
                    for key in candidates:
                        if key in msg:
                            value = msg[key]
                            break
                else:
                    for key in candidates:
                        if hasattr(msg, key):
                            value = getattr(msg, key)
                            break

                if value is not None:
                    try:
                        pwm = float(value)
                        # Descarta valores fuera del rango PWM físico
                        if PWM_MIN <= pwm <= PWM_MAX:
                            motors[f'Motor{i}'].append(pwm)
                    except (TypeError, ValueError):
                        pass

        if not any(motors.values()):
            print(
                "⚠ Se encontraron mensajes de salida, "
                "pero sin canales de motores válidos"
            )
            return

        plt.figure(figsize=(14, 8))
        for i, (motor_name, values) in enumerate(motors.items(), 1):
            if values:
                plt.subplot(2, 4, i)
                plt.plot(values, linewidth=1.5, color=f'C{i - 1}')
                plt.title(self._title_with_city(motor_name))
                plt.xlabel('Tiempo')
                plt.ylabel('PWM (µs)')
                plt.grid(True, alpha=0.3)

        plt.suptitle(
            self._title_with_city('Velocidad de Motores del Octorotor'),
            fontsize=14,
            fontweight='bold',
        )
        plt.tight_layout()
        self._save_figure(plt.gcf(), 'motores')
        plt.show()

    def visualize_imu(self):
        """Grafica los datos del IMU: acelerómetro y giroscopio.

        Fuente de datos: campos ``AccX/Y/Z`` y ``GyrX/Y/Z`` de
        mensajes ``IMU``.  Genera dos subgráficas en la misma figura.
        """
        if 'IMU' not in self.data:
            print("⚠ Datos de IMU no encontrados")
            return

        imu = self._extract_series(
            'IMU', ('AccX', 'AccY', 'AccZ', 'GyrX', 'GyrY', 'GyrZ')
        )

        fig, axes = plt.subplots(2, 1, figsize=(12, 8))

        # --- Subgráfica superior: acelerómetro ---
        axes[0].plot(imu['AccX'], label='AccX', linewidth=1, alpha=0.7)
        axes[0].plot(imu['AccY'], label='AccY', linewidth=1, alpha=0.7)
        axes[0].plot(imu['AccZ'], label='AccZ', linewidth=1, alpha=0.7)
        axes[0].set_ylabel('Aceleración (m/s²)')
        axes[0].set_title(self._title_with_city('Acelerómetro del IMU'))
        axes[0].legend()
        axes[0].grid(True, alpha=0.3)

        # --- Subgráfica inferior: giroscopio ---
        axes[1].plot(imu['GyrX'], label='GyrX', linewidth=1, alpha=0.7)
        axes[1].plot(imu['GyrY'], label='GyrY', linewidth=1, alpha=0.7)
        axes[1].plot(imu['GyrZ'], label='GyrZ', linewidth=1, alpha=0.7)
        axes[1].set_xlabel('Tiempo (muestras)')
        axes[1].set_ylabel('Velocidad angular (rad/s)')
        axes[1].set_title(self._title_with_city('Giroscopio del IMU'))
        axes[1].legend()
        axes[1].grid(True, alpha=0.3)

        fig = plt.gcf()
        self._save_figure(fig, 'imu')

