def compare_agl_panels(visualizers):
    """Crea una figura 2+1 con la altura AGL de cada ciudad."""
    fig, axes = _create_city_panel_figure()
    plotted = False
    legend_handles = None
    legend_labels = None

    for key, ax in axes.items():
        viz = visualizers.get(key)
        if viz is None or 'TERR' not in viz.data:
            ax.axis('off')
            continue
        agl_raw = viz._extract_series('TERR', ('CHeight',))['CHeight']
        if not agl_raw or all(v == 0 for v in agl_raw):
            ax.axis('off')
            continue
        # Elimina artefacto de inicialización y fase en tierra previa al despegue
        first_stable = next((i for i, h in enumerate(agl_raw) if h <= 0.1), 0)
        first_flight = next(
            (i for i, h in enumerate(agl_raw)
             if i >= first_stable and h > 1.0),
            first_stable,
        )
        trim = max(0, first_flight - 5)
        t_raw = (
            viz._build_time_axis_seconds_global('TERR')
            or list(range(len(agl_raw)))
        )
        agl = agl_raw[trim:]
        t_s = t_raw[trim:]
        if not agl:
            ax.axis('off')
            continue
        ax.fill_between(t_s, 0, agl, color='#c49a6c', alpha=0.35, label='Terreno')
        ax.plot(t_s, agl, linewidth=1.7, color='orange', label='AGL')
        _style_city_panel_axis(ax, key, 'Tiempo (s)', 'Altura AGL (m)')
        if legend_handles is None:
            legend_handles, legend_labels = ax.get_legend_handles_labels()
        plotted = True

    if not plotted:
        plt.close(fig)
        print("⚠ No hay datos AGL para comparar")
        return

    _hide_unused_city_axes(axes, visualizers)
    _figure_legend(fig, legend_handles, legend_labels, ncol=2, y=0.01)
    fig.tight_layout(rect=(0.0, 0.07, 1.0, 1.0), pad=0.1)
