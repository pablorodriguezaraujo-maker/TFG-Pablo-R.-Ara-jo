    def report_route_metrics(self):
        """Imprime un resumen de distancia, tiempo y velocidad media.

        Utiliza los puntos GPS válidos obtenidos con
        ``_get_valid_gps_points()`` y la distancia Haversine entre
        puntos consecutivos.  El tiempo total se deduce de ``TimeUS``.
        """
        points = self._get_valid_gps_points()
        if len(points) < 2:
            print("⚠ No hay suficientes puntos GPS válidos para calcular ruta")
            return

        # Suma de distancias entre puntos GPS consecutivos
        total_m = sum(
            self._haversine_m(
                points[i - 1][0], points[i - 1][1],
                points[i][0], points[i][1]
            )
            for i in range(1, len(points))
        )

        # Tiempo total usando timestamps en microsegundos
        times = [p[2] for p in points if p[2] is not None]
        if len(times) >= 2:
            total_s = max(0.0, (times[-1] - times[0]) / US_TO_S)
        else:
            total_s = float('nan')

        print("\n=== Resumen de Ruta ===")
        print(f"Puntos GPS válidos : {len(points)}")
        print(
            f"Distancia recorrida: {total_m:.2f} m "
            f"({total_m / 1000:.3f} km)"
        )
        if math.isnan(total_s):
            print("Tiempo total       : no disponible (TimeUS no encontrado)")
        else:
            print(
                f"Tiempo total       : {total_s:.2f} s "
                f"({total_s / 60:.2f} min)"
            )
            if total_s > 0:
                v_ms = total_m / total_s
                print(
                    f"Velocidad media    : {v_ms:.2f} m/s "
                    f"({v_ms * 3.6:.2f} km/h)"
                )

