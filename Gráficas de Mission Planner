    def visualize_attitude(self):
        """Grafica la actitud del dron: Roll, Pitch y Yaw.

        Fuente de datos: mensajes ``ATT``.
        Los ángulos se expresan en grados.
        """
        if 'ATT' not in self.data:
            print("⚠ Datos de ATT (actitud) no encontrados")
            return

        series = self._extract_series('ATT', ('Roll', 'Pitch', 'Yaw'))

        plt.figure(figsize=(12, 6))
        plt.plot(series['Roll'], label='Roll', linewidth=2)
        plt.plot(series['Pitch'], label='Pitch', linewidth=2)
        plt.plot(series['Yaw'], label='Yaw', linewidth=2)
        plt.xlabel('Tiempo (muestras)')
        plt.ylabel('Ángulo (grados)')
        plt.title(
            self._title_with_city('Actitud del Octorotor (Roll, Pitch, Yaw)')
        )
        plt.legend()
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        self._save_figure(plt.gcf(), 'actitud')
        plt.show()

    def visualize_altitude(self):
        """Grafica la altitud barométrica del dron.

        Fuente de datos: campo ``Alt`` de mensajes ``BARO``.
        """
        if 'BARO' not in self.data:
            print("⚠ Datos de BARO (altitud) no encontrados")
            return

        altitude = self._extract_series('BARO', ('Alt',))['Alt']

        plt.figure(figsize=(12, 6))
