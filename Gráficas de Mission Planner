# Metros por grado de latitud (aproximación esférica)
LAT_TO_M = 111_320.0


def _normalize_to_percent(values, n_points=100):
    """Remuestrea una serie a ``n_points`` puntos equiespaciados (0-100 %).

    Permite comparar series de distinta longitud sobre el mismo eje X
    que representa el porcentaje de progreso del vuelo.

    Parámetros:
        values (list[float]): Serie original de cualquier longitud.
        n_points (int): Número de puntos de la serie de salida.

    Devuelve:
        list[float]: Serie interpolada linealmente de ``n_points`` valores.
    """
    n = len(values)
    if n == 0:
        return []
    if n == 1:
        return [values[0]] * n_points

    result = []
    for i in range(n_points):
        idx_f = i * (n - 1) / (n_points - 1)
        idx_lo = int(idx_f)
        idx_hi = min(idx_lo + 1, n - 1)
        frac = idx_f - idx_lo
        result.append(values[idx_lo] * (1 - frac) + values[idx_hi] * frac)
    return result


def _save_comparison_figure(fig, base_filename):
    """Guarda una figura de comparativa en la carpeta comparativas.

    Parámetros:
        fig: Objeto figura de matplotlib.
        base_filename (str): Nombre base sin extensión, p.ej.
            'velocidad_comparativa'.
    """
    COMPARISON_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    filename = f"{base_filename}.png"
    filepath = COMPARISON_OUTPUT_DIR / filename
    try:
        fig.savefig(filepath, dpi=100, bbox_inches='tight')
        print(f"  ✓ Comparativa guardada: {filepath.name}")
    except Exception as exc:
        print(f"  ✗ Error guardando {filename}: {exc}")


def _load_all_visualizers():
    """Carga los tres logs y devuelve un diccionario clave → visualizador.

    Solo incluye las ciudades cuyos archivos existen en disco.

    Devuelve:
        dict[str, MissionPlannerVisualizer]: Visualizadores ya cargados.
    """
    visualizers = {}
    for key in CITY_ORDER:
        log_path = CITY_LOG_FILES[key]
        label = CITY_LABELS[key]
        if not Path(log_path).exists():
            print(f"⚠ No se encontró el log de {label}: {log_path}")
            continue
        try:
            viz = MissionPlannerVisualizer(log_path, label, city_key=key)
            viz.read_log()
            visualizers[key] = viz
            print(f"✓ {label} cargada")
        except Exception as exc:
            print(f"⚠ Error cargando {label}: {exc}")
    return visualizers


def compare_speed(visualizers):
    """Superpone los perfiles de velocidad suavizada de las tres ciudades.

    Normaliza el tiempo de cada vuelo a 0-100 % para que las curvas
    sean comparables con independencia de la duración total del vuelo.

    Parámetros:
        visualizers (dict): Visualizadores cargados por clave de ciudad.
    """
    x = list(range(100))

    plt.figure(figsize=(13, 6))
    plotted = False

    for key in CITY_ORDER:
        if key not in visualizers:
            continue
        _, speed_kmh = visualizers[key]._compute_speed_series()
        if len(speed_kmh) < 2:
            continue
        smooth = MissionPlannerVisualizer._moving_average(
            speed_kmh, window=SMOOTHING_WINDOW
        )
        plt.plot(
            x, _normalize_to_percent(smooth),
            linewidth=2.5,
            label=CITY_LABELS[key],
            color=CITY_COLORS[key],
        )
        plotted = True

    if not plotted:
        print("⚠ No hay datos de velocidad para comparar")
        return

    plt.xlabel('Progreso del vuelo (%)')
    plt.ylabel('Velocidad (km/h)')
    plt.title('Comparativa de Velocidad — A Coruña · Santiago · Vigo')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    _save_comparison_figure(plt.gcf(), 'velocidad_comparativa')
    plt.show()


