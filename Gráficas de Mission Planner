    def generate_all_plots(self):
        """Ejecuta todas las gráficas disponibles en orden.

        Cada gráfica se ejecuta en un bloque ``try/except`` para que
        un fallo en una no impida el resto.
        """
        print(f"\n{SEPARATOR}")
        print("Generando todas las gráficas...")
        print(f"{SEPARATOR}\n")

        graficas = [
            ('actitud', self.visualize_attitude),
            ('altitud', self.visualize_altitude),
            ('altitud sobre terreno', self.visualize_altitude_terrain),
            ('GPS', self.visualize_gps),
            ('motores', self.visualize_motors),
            ('IMU', self.visualize_imu),
            ('batería', self.visualize_battery),
            ('velocidad', self.visualize_speed),
        ]

        for nombre, metodo in graficas:
            try:
                metodo()
            except Exception as exc:
                print(f"Error en {nombre}: {exc}")

        print("\n✓ Visualización completada")


