    def visualize_altitude_terrain(self):
        """Grafica la altura sobre el terreno (AGL).

        Fuente de datos: campo ``CHeight`` de mensajes ``TERR``.
        """
        if 'TERR' not in self.data:
            print("⚠ Datos de TERR (terreno) no encontrados")
            return

        agl_raw = self._extract_series('TERR', ('CHeight',))['CHeight']

        if not agl_raw or all(v == 0 for v in agl_raw):
            print("⚠ No hay valores válidos de altura sobre terreno (CHeight)")
            return

        # Elimina el artefacto de inicialización del firmware de terreno:
        # algunos logs comienzan con CHeight != 0 antes de que el sistema
        # se calibre.  Además recorta la larga fase en tierra previa al
        # despegue para que la escala temporal de la gráfica sea útil.
        first_stable = next((i for i, h in enumerate(agl_raw) if h <= 0.1), 0)
        first_flight = next(
            (i for i, h in enumerate(agl_raw)
             if i >= first_stable and h > 1.0),
            first_stable,
        )
        trim = max(0, first_flight - 5)
        t_raw = (
            self._build_time_axis_seconds_global('TERR')
            or list(range(len(agl_raw)))
        )
        agl = agl_raw[trim:]
        x = t_raw[trim:]

        if not agl or all(v == 0 for v in agl):
            print("⚠ No hay valores de vuelo válidos de altura sobre terreno")
            return

        plt.figure(figsize=(CITY_PLOT_WIDTH_IN, CITY_PLOT_HEIGHT_IN))
        # Rellena el área entre el terreno (0) y la altura AGL.
        plt.fill_between(
            x,
            0,
            agl,
            color='#c49a6c',
            alpha=0.35,
            label='Terreno',
        )
        plt.plot(
            x,
            agl,
            label='Altura sobre terreno\n(AGL)',
            linewidth=2,
            color='orange',
        )
        plt.xlabel('Tiempo (s)', labelpad=2)
        plt.ylabel('Altura sobre terreno (m)')
        self._legend_below(plt.gca(), ncol=2, y=-0.36)
        plt.grid(True, alpha=0.3)
        plt.tight_layout(rect=(0.0, 0.22, 1.0, 1.0))
        self._save_figure(plt.gcf(), 'altitud_terreno')
        plt.show()

