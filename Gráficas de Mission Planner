    def visualize_speed(self):
        """Grafica la velocidad del dron a lo largo de la ruta.

        Fuente primaria: campo ``Spd`` de mensajes ``GPS``, que suele
        ser la velocidad sobre tierra (ground speed) calculada por el
        receptor GPS.  Si no está disponible, se calcula derivando la
        distancia Haversine entre puntos GPS consecutivos.

        Muestra dos series:
        - Velocidad bruta (gris semitransparente).
        - Velocidad suavizada con media móvil de ventana ``SMOOTHING_WINDOW``
          (línea morada).
        """
        if 'GPS' not in self.data:
            print("⚠ Datos de GPS no encontrados")
            return

        elapsed_s, speed_kmh = self._compute_speed_series()
        t_start = self._get_flight_start_s()
        if t_start > 0:
            pairs = [(t, s) for t, s in zip(elapsed_s, speed_kmh) if t >= t_start]
            if len(pairs) >= 2:
                elapsed_s, speed_kmh = map(list, zip(*pairs))

        if len(speed_kmh) < 2:
            print("⚠ No hay suficientes datos para graficar velocidad")
            return

        speed_smooth = self._moving_average(speed_kmh, window=SMOOTHING_WINDOW)

        plt.figure(figsize=(CITY_PLOT_WIDTH_IN, CITY_PLOT_HEIGHT_IN))
        plt.plot(
            elapsed_s, speed_kmh,
            linewidth=1.0, alpha=0.35, color='gray',
            label='Vel. bruta',
        )
        plt.plot(
            elapsed_s, speed_smooth,
            linewidth=2.0, color='purple',
            label='Vel. suavizada',
        )
        plt.xlabel('Tiempo (s)', labelpad=2)
        plt.ylabel('Velocidad (km/h)')
        self._legend_below(plt.gca(), ncol=2, y=-0.20)
        plt.grid(True, alpha=0.3)
        plt.tight_layout(rect=(0.0, 0.13, 1.0, 1.0))
        self._save_figure(plt.gcf(), 'velocidad')
        plt.show()

    def _compute_speed_series(self):
        """Calcula las series de tiempo y velocidad en km/h.

        Intenta primero usar el campo ``Spd`` nativo del GPS (más
        estable).  Como respaldo calcula la velocidad derivando la
        distancia Haversine entre puntos consecutivos.

        Devuelve:
            tuple[list[float], list[float]]: ``(elapsed_s, speed_kmh)``
            con el tiempo transcurrido desde el primer punto (en s) y
            la velocidad correspondiente (en km/h).
        """
        raw_t = []
        raw_spd = []

        for msg in self.data['GPS']:
            if isinstance(msg, dict):
                t_us = msg.get('TimeUS')
                spd = msg.get('Spd')
            else:
                t_us = getattr(msg, 'TimeUS', None)
                spd = getattr(msg, 'Spd', None)

            if t_us is None or spd is None:
                continue

            try:
                raw_t.append(float(t_us))
                raw_spd.append(float(spd))
            except (TypeError, ValueError):
                continue

        if len(raw_t) >= 2:
            return self._speed_from_spd_field(raw_t, raw_spd)

        # Respaldo: derivar velocidad a partir de coordenadas GPS
        return self._speed_from_gps_points()

    def _speed_from_spd_field(self, raw_t, raw_spd):
        """Convierte el campo ``Spd`` del GPS a km/h con eje temporal.

        Detecta automáticamente si los valores están en m/s o cm/s
        comparando la mediana con ``SPEED_CMS_THRESHOLD``.

        Parámetros:
            raw_t (list[float]): Timestamps en microsegundos.
            raw_spd (list[float]): Velocidades tal como las devuelve el log.

        Devuelve:
            tuple[list[float], list[float]]: ``(elapsed_s, speed_kmh)``.
        """
        # Detección de unidades: si la mediana supera el umbral, son cm/s
        median_spd = sorted(raw_spd)[len(raw_spd) // 2]
        scale = 0.01 if median_spd > SPEED_CMS_THRESHOLD else 1.0

        elapsed_s = []
        speed_kmh = []
        t0 = self._get_global_t0_us() or raw_t[0]
        last_t = None

        for t_us, spd in zip(raw_t, raw_spd):
            t_sec = (t_us - t0) / US_TO_S
            # Descarta muestras con timestamp igual o anterior al previo
            if last_t is not None and t_sec <= last_t:
                continue
            elapsed_s.append(t_sec)
            speed_kmh.append(max(0.0, spd * scale * 3.6))
            last_t = t_sec

        return elapsed_s, speed_kmh

    def _speed_from_gps_points(self):
        """Calcula la velocidad derivando distancia entre puntos GPS.

        Método de respaldo cuando el campo ``Spd`` no está disponible.

        Devuelve:
            tuple[list[float], list[float]]: ``(elapsed_s, speed_kmh)``.
        """
        points = self._get_valid_gps_points()
        if len(points) < 2:
            print(
                "⚠ No hay suficientes puntos GPS válidos "
                "para calcular velocidad"
            )
            return [], []

        t0 = self._get_global_t0_us() or points[0][2]
        elapsed_s = [0.0]
        speed_kmh = [0.0]

        for i in range(1, len(points)):
            lat1, lon1, t1_us = points[i - 1]
            lat2, lon2, t2_us = points[i]
            dist_m = self._haversine_m(lat1, lon1, lat2, lon2)

            if t1_us is not None and t2_us is not None:
                dt_s = (t2_us - t1_us) / US_TO_S
                spd_kmh = (dist_m / dt_s) * 3.6 if dt_s > 0 else 0.0
                t_sec = (
                    (t2_us - t0) / US_TO_S
                    if t0 is not None
                    else float(i)
                )
            else:
                spd_kmh = 0.0
                t_sec = float(i)

            elapsed_s.append(t_sec)
            speed_kmh.append(max(0.0, spd_kmh))

        return elapsed_s, speed_kmh

