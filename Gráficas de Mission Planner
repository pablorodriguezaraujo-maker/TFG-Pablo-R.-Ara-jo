def _style_city_panel_axis(ax, city_key, xlabel, ylabel, equal_aspect=False):
    """Aplica estilo homogéneo a un eje comparativo por ciudad."""
    ax.set_title(f"{_panel_label(city_key)} {CITY_LABELS[city_key]}", fontsize=11, pad=6)
    ax.set_xlabel(xlabel, fontsize=11, labelpad=0)
    if city_key == 'santiago':
        ax.set_ylabel('')
        ax.yaxis.set_label_position('right')
        ax.yaxis.tick_right()
        ax.tick_params(axis='y', labelright=True, labelleft=False, pad=2)
    else:
        ax.set_ylabel(ylabel, fontsize=11)
        ax.yaxis.set_label_position('left')
        ax.yaxis.tick_left()
        ax.tick_params(axis='y', labelleft=True, labelright=False)
    ax.tick_params(axis='both', labelsize=11)
    ax.grid(True, alpha=0.3)
