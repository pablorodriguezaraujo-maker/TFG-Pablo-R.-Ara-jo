def _print_pending_cities(city_order, city_labels, used_cities):
    """Imprime el menú de ciudades indicando cuáles ya se han ejecutado.

    Parámetros:
        city_order (list[str]): Claves de ciudad en orden de presentación.
        city_labels (dict[str, str]): Nombre completo por clave.
        used_cities (set[str]): Ciudades ya procesadas.
    """
    print("Ciudades pendientes:")
    for idx, key in enumerate(city_order, 1):
        estado = " (ya ejecutada)" if key in used_cities else ""
        print(f"  {idx}. {city_labels[key]}{estado}")
    print("  0. Salir")


def _run_city_session(visualizer):
    """Muestra el menú de gráficas y ejecuta las seleccionadas.

    Parámetros:
        visualizer (MissionPlannerVisualizer): Instancia ya cargada
            con el log de la ciudad correspondiente.
    """
    print("\nOpciones disponibles:")
    opciones = [
        ("1", "Actitud (Roll, Pitch, Yaw)"),
        ("2", "Altitud"),
        ("3", "GPS"),
        ("4", "Motores"),
        ("5", "IMU"),
        ("6", "Batería"),
        ("7", "Altitud sobre terreno (AGL)"),
        ("8", "Velocidad"),
        ("9", "Todas las gráficas"),
        ("0", "Omitir esta ciudad"),
    ]
    for num, desc in opciones:
        print(f"  {num}. {desc}")

    eleccion = input(
        "\nSelecciona opción(es) (0-9). "
        "Puedes poner varias separadas por coma, p.ej. 1,2,7: "
    ).strip()

    if not eleccion:
        print("No se seleccionó ninguna opción")
        return

    seleccionadas = [c.strip() for c in eleccion.split(',') if c.strip()]

    if '0' in seleccionadas:
        print("Ciudad omitida (sin gráficas).")
        return

    if '9' in seleccionadas:
        visualizer.generate_all_plots()
        return

    acciones = {
        '1': visualizer.visualize_attitude,
        '2': visualizer.visualize_altitude,
        '3': visualizer.visualize_gps,
        '4': visualizer.visualize_motors,
        '5': visualizer.visualize_imu,
        '6': visualizer.visualize_battery,
        '7': visualizer.visualize_altitude_terrain,
        '8': visualizer.visualize_speed,
    }

    ejecutadas = 0
    for opt in seleccionadas:
        accion = acciones.get(opt)
        if accion is None:
            print(f"Opción no válida: {opt}")
            continue
        print(f"\nEjecutando opción {opt}...")
        accion()
        ejecutadas += 1

    if ejecutadas == 0:
        print("No se ejecutó ninguna opción válida")


def main():
    """Punto de entrada del programa.

    Muestra un menú interactivo para seleccionar ciudad, carga el log
    correspondiente, imprime el resumen de ruta y lanza las gráficas
    elegidas.  El bucle termina cuando se han procesado las tres ciudades
    o el usuario elige salir.
    """
    print(SEPARATOR)
    print("VISUALIZADOR DE LOGS DE MISSION PLANNER - OCTOROTOR")
    print(SEPARATOR + "\n")

    used_cities = set()

    while len(used_cities) < len(CITY_ORDER):
        _print_pending_cities(CITY_ORDER, CITY_LABELS, used_cities)

        eleccion = input("\nSelecciona ciudad (1-3 o nombre): ").strip().lower()

        if eleccion == '0':
            print("Saliendo...")
            return

        city_key = CITY_ALIASES.get(eleccion)
        if city_key is None:
            print("Ciudad no válida. Elige A Coruña, Santiago o Vigo.")
            continue

        if city_key in used_cities:
            print("Esa ciudad ya se ejecutó. Elige otra.")
            continue

        log_path = CITY_LOG_FILES[city_key]
        city_label = CITY_LABELS[city_key]

        if not Path(log_path).exists():
            print(f"No se encontró el log para {city_label}: {log_path}")
            used_cities.add(city_key)
            continue

        print(f"\nCiudad seleccionada: {city_label}")
        print(f"Archivo de log     : {log_path}")

        try:
            visualizer = MissionPlannerVisualizer(log_path, city_label,
                                                 city_key=city_key)
            visualizer.read_log()
            visualizer.report_route_metrics()
            _run_city_session(visualizer)

        except Exception as exc:
            import traceback
            print(f"Error procesando {city_label}: {exc}")
            traceback.print_exc()

        finally:
            used_cities.add(city_key)
            restantes = len(CITY_ORDER) - len(used_cities)
            if restantes > 0:
                print(
                    f"\nCiudad completada. "
                    f"Quedan {restantes} ciudad(es) por ejecutar.\n"
                )
    print("\n✅ Ya se ejecutaron las tres ciudades.")

    # Ofrecer gráficas comparativas entre las tres ciudades
    resp = input(
        "\n¿Generar gráficas comparativas de las tres ciudades? (s/n): "
    ).strip().lower()
    if resp in ('s', 'si', 'sí', 'y', 'yes'):
        print("\nCargando los tres logs para comparación...")
        vizs = _load_all_visualizers()
        if len(vizs) >= 2:
            _run_comparison_session(vizs)
        else:
            print("⚠ Se necesitan al menos 2 ciudades para comparar")

    print("\nFin del programa.")


if __name__ == "__main__":
    main()
